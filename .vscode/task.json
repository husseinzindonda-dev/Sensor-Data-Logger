{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: main app",
      "type": "shell",
      "command": "gcc",
      "args": [
        "src/buffer.c",
        "src/sensors.c",
        "src/main.c",
        "-o",
        "build/sensor_logger.exe",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-std=c11",
        "-g"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "build: test_buffer",
      "type": "shell",
      "command": "gcc",
      "args": [
        "src/buffer.c",
        "tests/test_buffer.c",
        "-o",
        "build/test_buffer.exe",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-std=c11",
        "-g"
      ],
      "group": "build",
      "problemMatcher": "$gcc",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "build: test_sensor",
      "type": "shell",
      "command": "gcc",
      "args": [
        "src/buffer.c",
        "src/sensors.c",
        "tests/test_sensor.c",
        "-o",
        "build/test_sensor.exe",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-std=c11",
        "-g",
        "-lm"
      ],
      "group": "build",
      "problemMatcher": "$gcc",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "build: all",
      "dependsOn": [
        "build: main app",
        "build: test_buffer",
        "build: test_sensor"
      ],
      "group": "build",
      "problemMatcher": []
    }
  ]
}
